# Copia questo file in ".env" (stesso nome, senza ".example") e incolla la tua chiave.
# Il file ".env" non viene mai caricato su git (è in .gitignore).
ANTHROPIC_API_KEY=sk-ant-la-tua-chiave-qui
SECRET_KEY=genera-una-stringa-lunga-e-casuale-qui

# Metti "true" solo sul server online (PythonAnywhere, servito in https).
# In locale (http://127.0.0.1) deve restare "false", altrimenti login/CSRF non funzionano.
SESSION_COOKIE_SECURE=false
